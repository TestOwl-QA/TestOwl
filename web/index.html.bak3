<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>TestOwl</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,"PingFang SC","Microsoft YaHei",sans-serif;background:#FAF8F5;display:flex;min-height:100vh}
.sidebar{width:180px;background:#F5F0E8;padding:20px 16px;border-right:1px solid #E0D8CC;display:flex;flex-direction:column;position:fixed;left:0;top:0;bottom:0}
.sidebar h1{font-size:16px;color:#5D4E37;margin-bottom:24px;font-weight:600}
.nav-item{padding:8px 10px;margin:2px 0;border-radius:4px;cursor:pointer;color:#4A4A4A;font-size:13px;display:flex;align-items:center}
.nav-item:hover{background:#EBE4D8}
.nav-item.active{background:#E8E0D0;color:#5D4E37}
.nav-item svg{width:14px;height:14px;margin-right:8px;stroke:currentColor;fill:none;stroke-width:1.5}
.main{flex:1;margin-left:180px;display:flex;flex-direction:column;min-height:100vh}
.chat-view{flex:1;display:flex;flex-direction:column;max-width:800px;margin:0 auto;width:100%;padding-bottom:80px}
.chat-messages{flex:1;overflow-y:auto;padding:20px}
.msg{margin:16px 0;display:flex}
.msg.user{justify-content:flex-end}
.msg.user .bubble{background:#A89070;color:white;border-radius:16px 16px 4px 16px}
.msg.assistant{justify-content:flex-start}
.msg.assistant .bubble{background:white;color:#4A4A4A;border-radius:16px 16px 16px 4px;border:1px solid #E8E0D0;position:relative}
.bubble{padding:12px 28px 12px 16px;max-width:70%;font-size:14px;line-height:1.6}
.export-icon{position:absolute;top:6px;right:6px;cursor:pointer;opacity:0.3;font-size:14px}
.export-icon:hover{opacity:0.7}
.chat-input-area{position:fixed;bottom:0;left:180px;right:0;padding:12px 20px;background:#FAF8F5;border-top:1px solid #E8E0D0;z-index:100}
.input-box{position:relative;max-width:800px;margin:0 auto}
.input-box textarea{width:100%;padding:14px 80px 14px 40px;border:1px solid #D8D0C0;border-radius:12px;font-size:14px;resize:none;height:100px;min-height:100px;max-height:300px;font-family:-apple-system,"PingFang SC","Microsoft YaHei",sans-serif}
.input-box textarea:focus{outline:none;border-color:#A89070}
.input-box button{position:absolute;right:10px;bottom:10px;padding:8px 16px;background:#B8A090;color:white;border:none;border-radius:6px;cursor:pointer;font-size:13px}
.input-box button:hover{background:#A89070}
.upload-btn{position:absolute;left:10px;bottom:12px;color:#B8A090;cursor:pointer;font-size:18px;z-index:10}
.upload-btn:hover{color:#A89070}
.tool-panel{display:none;padding:20px;max-width:800px;margin:0 auto;width:100%}
.tool-panel.active{display:block}
h2{color:#4A4A4A;font-size:15px;margin-bottom:16px}
.panel-box{background:white;border-radius:8px;padding:16px;border:1px solid #E8E0D0;margin-bottom:12px}
.panel-box label{display:block;color:#5D4E37;font-size:12px;margin-bottom:6px}
.panel-input{width:100%;height:100px;border:1px solid #D8D0C0;border-radius:4px;padding:8px;font-size:13px;font-family:-apple-system,"PingFang SC","Microsoft YaHei",sans-serif;resize:vertical}
input[type="password"]{width:100%;padding:8px;border:1px solid #D8D0C0;border-radius:4px;font-size:13px;font-family:-apple-system,"PingFang SC","Microsoft YaHei",sans-serif}
.drop-zone{border:2px dashed #D8D0C0;border-radius:6px;padding:20px;text-align:center;cursor:pointer}
.drop-zone:hover{border-color:#A89070}
.drop-zone p{color:#A89070;font-size:13px;margin:4px 0}
.drop-zone input{display:none}
.btn{padding:8px 16px;background:#B8A090;color:white;border:none;border-radius:4px;cursor:pointer;font-size:13px}
.btn:hover{background:#A89070}
.btn-outline{background:white;color:#5D4E37;border:1px solid #D8D0C0}
.result{background:white;border-radius:6px;padding:16px;margin-top:16px;border:1px solid #E8E0D0}
.result h3{color:#5D4E37;font-size:13px;margin-bottom:10px}
.item{padding:8px 10px;background:#F8F5F0;border-radius:4px;margin:6px 0;font-size:13px}
.status{font-size:11px;padding:3px 6px;border-radius:3px;background:#E8F5E9;color:#2E7D32}
.report-menu{display:none;position:fixed;background:white;border:1px solid #E8E0D0;border-radius:6px;padding:12px;box-shadow:0 2px 12px rgba(0,0,0,0.15);z-index:1000}
.export-btn{display:block;width:100%;margin:4px 0;padding:6px;background:#D4C4B0;color:white;border:none;border-radius:4px;cursor:pointer;font-size:12px}
.export-btn:hover{background:#B8A090}
</style>
</head>
<body>
<div class="sidebar">
<h1>TestOwl</h1>
<div class="nav-item active" onclick="switchView('chat')"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>对话</div>
<div class="nav-item" onclick="switchView('apikey')"><svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/></svg>API Key配置</div>
<div class="nav-item" onclick="switchView('generate')"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></div>
<div class="nav-item" onclick="switchView('check')"><svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg></div>
<div class="nav-item" onclick="switchView('settings')" style="margin-top:auto"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>设置</div>
</div>
<div class="main">
<div id="chatView" class="chat-view">
<div class="chat-messages" id="chatMessages">
<div class="msg assistant"><div class="bubble"><span class="export-icon" onclick="showExportMenu(event,this)">📄</span>你好，我是 TestOwl，可以帮你分析测试需求、生成测试用例、检查配置表。</div></div>
</div>
</div>
<div id="apikey" class="tool-panel">
<h2>API Key配置</h2>
<div class="panel-box"><label>输入文本</label><textarea class="panel-input" id="analyzeText"></textarea></div>
<div class="panel-box"><label>上传文件</label><div class="drop-zone" onclick="document.getElementById('analyzeFile').click()"><p>拖拽或点击选择</p><input type="file" id="analyzeFile" style="display:none"></div></div>
<button class="btn" onclick="doAnalyze()">分析</button>
<select id="reportFormat" style="margin-left:8px"><option value="md">MD</option><option value="pdf">PDF</option><option value="xlsx">Excel</option><option value="docx">Word</option></select>
<button class="btn btn-outline" id="dlBtn" style="display:none;margin-left:8px" onclick="dlReport()">下载</button>
<div class="result" id="analyzeResult" style="display:none"></div>
</div>
<div id="generate" class="tool-panel">
<h2>测试用例生成</h2>
<div class="panel-box"><label>需求描述</label><textarea class="panel-input" id="genText" style="height:150px"></textarea></div>
<button class="btn" onclick="doGenerate()">生成</button>
<div class="result" id="genResult" style="display:none"></div>
</div>
<div id="check" class="tool-panel">
<h2>配置表检查</h2>
<div class="panel-box"><label>上传文件</label><div class="drop-zone" onclick="document.getElementById('checkFile').click()"><p>拖拽或点击选择</p><input type="file" id="checkFile" style="display:none"></div></div>
<button class="btn" onclick="doCheck()">检查</button>
<div class="result" id="checkResult" style="display:none"></div>
</div>
<div id="settings" class="tool-panel">
<h2>设置</h2>
<div class="panel-box"><label>API Key</label><input type="password" id="apiKey"><button class="btn" onclick="saveKey()" style="margin-top:8px">保存</button><p id="keyStatus" style="margin-top:8px;font-size:12px;color:#666"></p></div>
</div>
</div>
<div class="chat-input-area">
<div class="input-box">
<span class="upload-btn" onclick="document.getElementById('chatFile').click()">📎</span>
<input type="file" id="chatFile" style="display:none" onchange="handleChatFile(this)">
<textarea id="chatInput" placeholder="输入消息..." onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMsg()}"></textarea>
<button onclick="sendMsg()">发送</button>
</div>
</div>
<div id="reportMenu" class="report-menu" onclick="event.stopPropagation()">
<button class="export-btn" onclick="exportSingle('md')">Markdown</button>
<button class="export-btn" onclick="exportSingle('pdf')">PDF</button>
<button class="export-btn" onclick="exportSingle('xlsx')">Excel</button>
<button class="export-btn" onclick="exportSingle('docx')">Word</button>
</div>
<script>
const API='http://121.41.36.197:8081';
let history=[],lastText='',currentExportContent='';
function switchView(v){
document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
event.currentTarget.classList.add('active');
document.getElementById('chatView').style.display=v==='chat'?'flex':'none';
document.querySelectorAll('.tool-panel').forEach(p=>p.classList.remove('active'));
if(v!=='chat')document.getElementById(v).classList.add('active');
}
function showExportMenu(e,el){
e.preventDefault();e.stopPropagation();
currentExportContent=el.parentElement.textContent;
const m=document.getElementById('reportMenu');
m.style.display='block';
m.style.left=(e.clientX-60)+'px';
m.style.top=(e.clientY+10)+'px';
}
function exportSingle(fmt){
const t=localStorage.getItem('session_token');
if(!t){alert('请先保存API Key');return;}
fetch(API+'/export_single',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({content:currentExportContent,format:fmt,session_token:t})})
.then(r=>r.json()).then(d=>{
if(d.success){const a=document.createElement('a');a.href='data:application/octet-stream;base64,'+d.file;a.download=d.filename;a.click();}
else alert('导出失败: '+d.error);
document.getElementById('reportMenu').style.display='none';
});
}
document.addEventListener('click',()=>document.getElementById('reportMenu').style.display='none');
async function handleChatFile(input){
const file=input.files[0];if(!file)return;
const t=localStorage.getItem('session_token');if(!t){alert('请先保存API Key');return;}
const fd=new FormData();fd.append('file',file);fd.append('session_token',t);
try{
const r=await fetch(API+'/upload',{method:'POST',body:fd});
const d=await r.json();
if(d.success)document.getElementById('chatInput').value+=d.text.substring(0,3000);
else alert('上传失败: '+d.error);
}catch(e){alert('网络错误');}
input.value='';
}
async function sendMsg(){
const t=localStorage.getItem('session_token');
if(!t){alert('请先在设置中保存API Key');return;}
const input=document.getElementById('chatInput'),msg=input.value.trim();if(!msg)return;
const msgs=document.getElementById('chatMessages');
msgs.innerHTML+='<div class="msg user"><div class="bubble">'+msg.replace(/</g,'&lt;')+'</div></div>';
input.value='';
history.push({role:'user',content:msg});
try{
const r=await fetch(API+'/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({messages:history,session_token:t})});
const d=await r.json();
const content=d.success?d.response:'错误:'+d.error;
msgs.innerHTML+='<div class="msg assistant"><div class="bubble"><span class="export-icon" onclick="showExportMenu(event,this)">📄</span>'+content.replace(/</g,'&lt;').replace(/\n/g,'<br>')+'</div></div>';
if(d.success)history.push({role:'assistant',content:d.response});
}catch(e){msgs.innerHTML+='<div class="msg assistant"><div class="bubble">网络错误</div></div>';}
msgs.scrollTop=msgs.scrollHeight;
}
async function saveKey(){
const k=document.getElementById('apiKey').value.trim();if(!k)return alert('请输入API Key');
const r=await fetch(API+'/auth/save_key',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({api_key:k})});
const d=await r.json();
if(d.success){localStorage.setItem('session_token',d.session_token);document.getElementById('apiKey').value='';document.getElementById('keyStatus').innerHTML='<span class="status">✓ 已保存</span>';}
}
async function doAnalyze(){
const t=localStorage.getItem('session_token');if(!t)return alert('请先保存API Key');
let text=document.getElementById('analyzeText').value.trim();
const file=document.getElementById('analyzeFile').files[0];
if(file){
const fd=new FormData();fd.append('file',file);fd.append('session_token',t);
document.getElementById('analyzeResult').innerHTML='<h3>解析中...</h3>';document.getElementById('analyzeResult').style.display='block';
const r=await fetch(API+'/upload',{method:'POST',body:fd});const d=await r.json();
if(d.success)text=d.text;else return document.getElementById('analyzeResult').innerHTML='<h3>失败</h3>'+d.error;
}
if(!text)return alert('请输入内容');
lastText=text;
document.getElementById('analyzeResult').innerHTML='<h3>分析中...</h3>';document.getElementById('analyzeResult').style.display='block';
const r=await fetch(API+'/analyze',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({text,session_token:t})});
const d=await r.json();
if(d.success&&d.data){renderRes(d.data);document.getElementById('dlBtn').style.display='inline-block';}
else document.getElementById('analyzeResult').innerHTML='<h3>失败</h3>'+(d.error||'');
}
function renderRes(d){
let h='<h3>分析结果</h3>';
if(d.document_summary)h+='<p style="margin-bottom:10px">'+d.document_summary+'</p>';
if(d.test_points&&d.test_points.length){h+='<h4 style="margin:10px 0 6px;color:#5D4E37">测试点</h4>';d.test_points.forEach(p=>{h+='<div class="item"><strong>#'+(p.id||'')+' '+(p.title||'')+'</strong><br>'+(p.description||'')+'</div>';});}
if(d.risk_points&&d.risk_points.length){h+='<h4 style="margin:10px 0 6px;color:#5D4E37">风险点</h4>';d.risk_points.forEach(r=>{h+='<div class="item">'+(r.description||'')+'</div>';});}
if(d.questions&&d.questions.length){h+='<h4 style="margin:10px 0 6px;color:#5D4E37">待确认</h4>';d.questions.forEach(q=>{h+='<div class="item">'+(q.question||'')+'</div>';});}
document.getElementById('analyzeResult').innerHTML=h;
}
async function doGenerate(){
const t=localStorage.getItem('session_token');if(!t)return alert('请先保存API Key');
const text=document.getElementById('genText').value.trim();if(!text)return alert('请输入需求');
document.getElementById('genResult').innerHTML='<h3>生成中...</h3>';document.getElementById('genResult').style.display='block';
const r=await fetch(API+'/generate_cases',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({text,session_token:t})});
const d=await r.json();
if(d.success)document.getElementById('genResult').innerHTML='<h3>测试用例</h3><pre style="white-space:pre-wrap;font-size:12px;background:#F8F5F0;padding:12px;border-radius:4px">'+JSON.stringify(d.data,null,2)+'</pre>';
else document.getElementById('genResult').innerHTML='<h3>失败</h3>'+d.error;
}
async function doCheck(){
const t=localStorage.getItem('session_token');if(!t)return alert('请先保存API Key');
const file=document.getElementById('checkFile').files[0];if(!file)return alert('请上传文件');
const fd=new FormData();fd.append('file',file);fd.append('session_token',t);
document.getElementById('checkResult').innerHTML='<h3>检查中...</h3>';document.getElementById('checkResult').style.display='block';
const r=await fetch(API+'/check_table',{method:'POST',body:fd});
const d=await r.json();
if(d.success)document.getElementById('checkResult').innerHTML='<h3>检查结果</h3><pre style="white-space:pre-wrap;font-size:12px;background:#F8F5F0;padding:12px;border-radius:4px">'+JSON.stringify(d.data,null,2)+'</pre>';
else document.getElementById('checkResult').innerHTML='<h3>失败</h3>'+d.error;
}
async function dlReport(){
const t=localStorage.getItem('session_token');if(!t||!lastText)return;
const fmt=document.getElementById('reportFormat').value;
const r=await fetch(API+'/export_single',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({content:lastText,format:fmt,session_token:t})});
const d=await r.json();
if(d.success){const a=document.createElement('a');a.href='data:application/octet-stream;base64,'+d.file;a.download=d.filename;a.click();}
else alert('导出失败: '+d.error);
}
window.onload=function(){if(localStorage.getItem('session_token'))document.getElementById('keyStatus').innerHTML='<span class="status">✓ 已配置</span>';};
</script>
</body>
</html>
