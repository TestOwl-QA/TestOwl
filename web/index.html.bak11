<!DOCTYPE html>
<html>
<head><link rel="icon" href="/assets/favicon.png" type="image/png">
<meta charset="UTF-8">
<title>TestOwl</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,"PingFang SC","Microsoft YaHei",sans-serif;background:#FAF8F5;display:flex;min-height:100vh}
.sidebar{width:180px;background:#F5F0E8;padding:20px 16px;border-right:1px solid #E0D8CC;display:flex;flex-direction:column;position:fixed;left:0;top:0;bottom:0}
.sidebar h1{font-size:16px;color:#5D4E37;margin-bottom:24px;font-weight:600}
.nav-item{padding:8px 10px;margin:2px 0;border-radius:4px;cursor:pointer;color:#4A4A4A;font-size:13px;display:flex;align-items:center}
.nav-item:hover{background:#EBE4D8}
.nav-item.active{background:#E8E0D0;color:#5D4E37}
.nav-item svg{width:14px;height:14px;margin-right:8px;stroke:currentColor;fill:none;stroke-width:1.5}
.main{flex:1;margin-left:180px;display:flex;flex-direction:column;min-height:100vh}
.chat-view{flex:1;display:flex;flex-direction:column;max-width:800px;margin:0 auto;width:100%;height:calc(100vh - 0px)}
.chat-messages{flex:1;overflow-y:auto;padding:20px;padding-bottom:100px}
.msg{margin:16px 0;display:flex}
.msg.user{justify-content:flex-end}
.msg.user .bubble{background:#A89070;color:white;border-radius:16px 16px 4px 16px}
.msg.assistant{justify-content:flex-start}
.msg.assistant .bubble{background:white;color:#4A4A4A;border-radius:16px 16px 16px 4px;border:1px solid #E8E0D0;position:relative}
.bubble{padding:12px 28px 12px 16px;max-width:70%;font-size:14px;line-height:1.6}
.export-icon{position:absolute;top:6px;right:6px;cursor:pointer;opacity:0.3;font-size:14px}
.export-icon:hover{opacity:0.7}
.chat-input-area{position:fixed;bottom:0;left:180px;right:0;padding:12px 20px;background:#FAF8F5;border-top:1px solid #E8E0D0;z-index:100}
.input-box{position:relative;max-width:800px;margin:0 auto}
.input-box textarea{width:100%;padding:14px 80px 14px 40px;border:1px solid #D8D0C0;border-radius:12px;font-size:14px;resize:none;height:100px;min-height:100px;max-height:300px;font-family:-apple-system,"PingFang SC","Microsoft YaHei",sans-serif}
.input-box textarea:focus{outline:none;border-color:#A89070}
.input-box button{position:absolute;right:10px;bottom:10px;padding:8px 16px;background:#B8A090;color:white;border:none;border-radius:6px;cursor:pointer;font-size:13px}
.input-box button:hover{background:#A89070}
.upload-btn{position:absolute;left:10px;bottom:12px;color:#B8A090;cursor:pointer;z-index:10}
.upload-btn:hover{color:#A89070}
.tool-panel{display:none;padding:20px;max-width:800px;margin:0 auto;width:100%}
.tool-panel.active{display:block}
h2{color:#4A4A4A;font-size:15px;margin-bottom:16px}
.panel-box{background:white;border-radius:8px;padding:16px;border:1px solid #E8E0D0;margin-bottom:12px}
.panel-box label{display:block;color:#5D4E37;font-size:12px;margin-bottom:6px}
.panel-input{width:100%;height:100px;border:1px solid #D8D0C0;border-radius:4px;padding:8px;font-size:13px;font-family:-apple-system,"PingFang SC","Microsoft YaHei",sans-serif;resize:vertical}
input[type="password"]{width:100%;padding:8px;border:1px solid #D8D0C0;border-radius:4px;font-size:13px;font-family:-apple-system,"PingFang SC","Microsoft YaHei",sans-serif}
.btn{padding:8px 16px;background:#B8A090;color:white;border:none;border-radius:4px;cursor:pointer;font-size:13px}
.btn:hover{background:#A89070}
.btn-outline{background:white;color:#5D4E37;border:1px solid #D8D0C0}
.report-menu{display:none;position:fixed;background:white;border:1px solid #E8E0D0;border-radius:6px;padding:12px;box-shadow:0 2px 12px rgba(0,0,0,0.15);z-index:1000}
.export-btn{display:block;width:100%;margin:4px 0;padding:6px;background:#D4C4B0;color:white;border:none;border-radius:4px;cursor:pointer;font-size:12px}
.export-btn:hover{background:#B8A090}
</style>
</head>
<body>
<div class="sidebar">
<h1>TestOwl</h1>
<div class="nav-item active" onclick="switchView('chat')">
<svg viewBox="0 0 24 24"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>对话
</div>
<div class="nav-item" onclick="switchView('apikey')">
<svg viewBox="0 0 24 24"><path d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>API Key配置
</div>
<div class="nav-item" onclick="switchView('settings')" style="margin-top:auto">
<svg viewBox="0 0 24 24"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>设置
</div>
</div>
<div class="main">
<div id="chatView" class="chat-view" style="display:flex">
<div class="chat-messages" id="chatMessages">
<div class="msg assistant"><div class="bubble">📄你好，我是 TestOwl，可以帮你分析测试需求、生成测试用例、检查配置表。</div></div>
</div>
<div class="chat-input-area">
<div class="input-box">
<div class="upload-btn" onclick="document.getElementById('fileInput').click()">
<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
</div>
<input type="file" id="fileInput" style="display:none" onchange="handleFile(this.files[0])">
<textarea id="userInput" placeholder="输入消息..."></textarea>
<button onclick="sendMessage()">发送</button>
</div>
</div>
</div>

<div id="apikey" class="tool-panel">
<h2>API Key配置</h2>
<div class="panel-box">
<label>API Key</label>
<input type="password" id="apiKey" placeholder="输入你的API Key">
</div>
<button class="btn" onclick="saveKey()">保存</button>
<span id="keyStatus" style="margin-left:10px;color:#5D4E37;font-size:12px"></span>
</div>

<div id="settings" class="tool-panel">
<h2>设置</h2>
<div class="panel-box">
<h3 style="color:#5D4E37;font-size:14px;margin-bottom:8px">Web自检</h3>
<p style="color:#8B7355;font-size:12px">自动化测试功能（开发中）</p>
<button class="btn btn-outline" style="margin-top:10px" onclick="runSelfTest()">运行自检
<div id="selfTestResult" style="display:none;margin-top:15px;padding:15px;background:#f8f8f8;border-radius:4px;font-size:13px"></div>
<div id="selfTestResult" style="display:none;margin-top:15px;padding:15px;background:#f8f8f8;border-radius:4px;font-size:13px"></div></button>
</div>
<div class="panel-box">
<h3 style="color:#5D4E37;font-size:14px;margin-bottom:8px">开发者模式</h3>
<p style="color:#8B7355;font-size:12px">代码编辑功能（开发中）</p>
<button class="btn btn-outline" style="margin-top:10px" onclick="alert('功能开发中，敬请期待')">进入开发者模式</button>
</div>
</div>
</div>

<div class="report-menu" id="reportMenu">
<button class="export-btn" onclick="exportChat('md')">Markdown</button>
<button class="export-btn" onclick="exportChat('pdf')">PDF</button>
<button class="export-btn" onclick="exportChat('xlsx')">Excel</button>
<button class="export-btn" onclick="exportChat('docx')">Word</button>
</div>

<script>
const API='http://121.41.36.197:8081';
let history=[],currentExportContent='';

function switchView(v){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  event.currentTarget.classList.add('active');
  document.getElementById('chatView').style.display=v==='chat'?'flex':'none';
  document.querySelectorAll('.tool-panel').forEach(p=>p.classList.remove('active'));
  if(v!=='chat')document.getElementById(v).classList.add('active');
}

async function saveKey(){
  const k=document.getElementById('apiKey').value.trim();
  if(!k)return alert('请输入API Key');
  const r=await fetch(API+'/auth/save_key',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({api_key:k})});
  const d=await r.json();
  if(d.success){localStorage.setItem('session_token',d.session_token);document.getElementById('apiKey').value='';document.getElementById('keyStatus').innerHTML='✓ 已保存';}
  else alert('保存失败: '+d.error);
}

async function sendMessage(){
  const t=localStorage.getItem('session_token');
  if(!t){alert('请先保存API Key');return;}
  const input=document.getElementById('userInput');
  const m=input.value.trim();
  if(!m)return;
  addMsg('user',m);
  input.value='';
  try{
    const r=await fetch(API+'/chat',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+t},body:JSON.stringify({message:m,history:history,session_token:t})});
    const d=await r.json();
    if(d.error)throw new Error(d.error);
    history.push({role:'user',content:m},{role:'assistant',content:d.response});
    addMsg('assistant',d.response);
  }catch(e){addMsg('assistant','错误: '+e.message);}
}

function addMsg(role,content){
  const div=document.createElement('div');
  div.className='msg '+role;
div.innerHTML='<div class="bubble">'+content+(role==='assistant'?'<span class="export-icon" onclick="showExportMenu(event,this.parentElement)">📋</span>':'')+'</div>';
  document.getElementById('chatMessages').appendChild(div);
document.getElementById('chatMessages').scrollTop=document.getElementById('chatMessages').scrollHeight;setTimeout(()=>{div.scrollIntoView({behavior:'smooth',block:'end'});},100);
}

function showExportMenu(e,el){
  e.preventDefault();e.stopPropagation();
  currentExportContent=el.textContent.replace('📋','');
  const m=document.getElementById('reportMenu');
  m.style.display='block';
  m.style.left=e.clientX+'px';
  m.style.top=e.clientY+'px';
  document.onclick=()=>{m.style.display='none';document.onclick=null;};
}

async function exportChat(fmt){
 const t=localStorage.getItem('session_token');
 if(!t){alert('请先保存API Key');return;}
 const r=await fetch(API+'/export_single',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+t},body:JSON.stringify({content:currentExportContent,format:fmt,session_token:t})});
 const d=await r.json();
 if(d.file){
 const bin=atob(d.file);
 const arr=new Uint8Array(bin.length);
 for(let i=0;i<bin.length;i++)arr[i]=bin.charCodeAt(i);
 const blob=new Blob([arr]);
 const a=document.createElement('a');
 a.href=URL.createObjectURL(blob);
 a.download=d.filename;
 a.click();
 }else if(d.error){
 alert('导出失败:'+d.error);
 }
}

async function handleFile(f){
  if(!f)return;
  const t=localStorage.getItem('session_token');
  if(!t){alert('请先保存API Key');return;}
  const fd=new FormData();
  fd.append('file',f);
  const r=await fetch(API+'/upload',{method:'POST',headers:{'Authorization':'Bearer '+t},body:fd});
  const d=await r.json();
  if(d.file_id){
    addMsg('user','上传了文件: '+f.name);
    addMsg('assistant','文件已上传，正在分析...');
  }
}

document.getElementById('userInput').addEventListener('keydown',e=>{
  if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();}
});

function runSelfTest(){
var resultEl = document.getElementById('selfTestResult');
resultEl.style.display = 'block';
resultEl.innerHTML = '<div style="color:#666">⏳ 自检中，请稍候...</div>';
fetch(API+'/health')
.then(r => r.json())
.then(d => {
var html = '';
if(d.status === 'ok'){
html += '<div style="color:#5D8A4E;font-weight:600;font-size:15px;margin-bottom:10px">✓ 自检通过</div>';
} else {
html += '<div style="color:#C45C4E;font-weight:600;font-size:15px;margin-bottom:10px">✗ 自检发现问题</div>';
}
html += '<div style="font-size:12px;color:#666;margin-bottom:8px">时间: ' + (d.timestamp || '-') + '</div>';
html += '<div style="border-top:1px solid #ddd;padding-top:10px">';
if(d.checks && d.checks.length > 0){
d.checks.forEach(function(check){
var icon = check.status === 'pass' ? '✓' : (check.status === 'warn' ? '⚠' : '✗');
var color = check.status === 'pass' ? '#5D8A4E' : (check.status === 'warn' ? '#B8860B' : '#C45C4E');
html += '<div style="margin:8px 0">';
html += '<span style="color:' + color + '">' + icon + '</span> ';
html += '<strong>' + check.name + '</strong>: ' + check.message;
if(check.traceback){
html += '<pre style="margin:5px 0 0 20px;padding:8px;background:#fff;font-size:11px;color:#C45C4E;border:1px solid #eee;overflow-x:auto">' + check.traceback + '</pre>';
}
html += '</div>';
});
}
html += '</div>';
resultEl.innerHTML = html;
})
.catch(e => {
resultEl.innerHTML = '<div style="color:#C45C4E;font-weight:600">✗ 连接失败</div><div style="font-size:12px;color:#666;margin-top:5px">' + e.message + '</div>';
});
}
</script>
</body>
</html>
