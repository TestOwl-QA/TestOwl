import asyncio
import os
import json
from typing import Any
import httpx
from mcp.server import Server
from mcp.server.sse import SseServerTransport
from starlette.applications import Starlette
from starlette.routing import Route
import uvicorn

# ==================== 配置区 ====================
KIMI_API_KEY = os.getenv("KIMI_API_KEY", "YOUR_API_KEY_HERE")
PORT = 8000

# ==================== 核心逻辑 ====================
app = Server("testowl")

async def analyze_code_with_kimi(code: str) -> str:
    """调用Kimi API分析代码"""
    url = "https://api.moonshot.cn/v1/chat/completions"
    headers = {
        "Authorization": f"Bearer {KIMI_API_KEY}",
        "Content-Type": "application/json"
    }
    data = {
        "model": "moonshot-v1-8k",
        "messages": [
            {
                "role": "user",
                "content": f"请分析以下代码:\n```\n{code}\n```\n\n请提供详细分析。"
            }
        ],
        "temperature": 0.3
    }
    
    async with httpx.AsyncClient() as client:
        response = await client.post(url, json=data, headers=headers, timeout=30.0)
        result = response.json()
        analysis = result['choices'][0]['message']['content']
        return analysis or "Analysis failed"

# ==================== MCP 工具定义 ====================
@app.call_tool()
async def call_tool(name: str, arguments: dict[str, Any]) -> list[dict[str, Any]]:
    if name == "analyze-code":
        code = arguments.get("code", "")
        if not code:
            return [{"type": "text", "text": "❌ No code provided"}]
        
        try:
            analysis = await analyze_code_with_kimi(code)
            return [{"type": "text", "text": analysis}]
        except Exception as e:
            return [{"type": "text", "text": f"❌ Error: {str(e)}"}]
    
    raise ValueError(f"Unknown tool: {name}")

@app.list_tools()
async def list_tools() -> list[dict[str, Any]]:
    return [
        {
            "name": "analyze-code",
            "description": "使用Kimi AI分析代码并返回详细报告",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "code": {"type": "string", "description": "需要分析的代码文本"}
                },
                "required": ["code"]
            }
        }
    ]

# ==================== SSE 传输层 ====================
sse = SseServerTransport("/messages")

async def handle_sse(scope, receive, send):
    """处理SSE连接"""
    async with sse.connect_sse(scope, receive, send) as streams:
        await app.run(
            streams[0],
            streams[1],
            app.create_initialization_options()
        )

async def handle_messages(scope, receive, send):
    """处理消息端点"""
    await sse.handle_post_message(scope, receive, send)

# ==================== Web 应用 ====================
starlette_app = Starlette(
    debug=True,
    routes=[
        Route("/sse", endpoint=handle_sse, methods=["GET"]),
        Route("/messages", endpoint=handle_messages, methods=["POST"]),
    ]
)

# ==================== 启动 ====================
if __name__ == "__main__":
    print(f"🚀 SSE MCP Server starting on http://0.0.0.0:{PORT}")
    print(f"📡 SSE endpoint: http://0.0.0.0:{PORT}/sse")
    uvicorn.run(starlette_app, host="0.0.0.0", port=PORT)